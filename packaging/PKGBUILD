pkgname=beatsketch-launcher-git
pkgver=0.0.0
pkgrel=1
pkgdesc=''
arch=('any')
url="https://github.com/BeatSketch/launcher"
license=('GPL3')
depends=('python', 'python-pyqt5', 'python-yaml')
makedepends=('git')
provides=('beatsketch-launcher')
conflicts=('beatsketch', 'beatsketch-launcher')
source=("$pkgname"::git+${url}.git)
sha256sums=('SKIP') # TODO: Add?

pkgver() {
    cd "${pkgname}"

    # TODO: For the non-git pkgbuild, need to use different output
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

